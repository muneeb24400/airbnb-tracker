# ─── Google Sheets Configuration ──────────────────────────────────────────────
# Your Google Sheet ID (from the URL: /spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# The tab/sheet name inside your spreadsheet (default: Bookings)
SHEET_NAME=Bookings

# ─── Google Service Account Credentials ───────────────────────────────────────
# Get these from your Google Cloud Console > Service Account > Keys > JSON
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour_private_key_here\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-client-id

# ─── Server Configuration ─────────────────────────────────────────────────────
PORT=5000

# ─── App Login Password ────────────────────────────────────────────────────────
# This is the password used to log into the StayTrack web app
APP_PASSWORD=staytrack2024

# ─── Activity Log Sheet ───────────────────────────────────────────────────────
# Name of the tab in Google Sheets where activity is logged (auto-created)
ACTIVITY_SHEET=ActivityLog

# ─── Properties Sheet ─────────────────────────────────────────────────────────
PROPERTIES_SHEET=Properties
